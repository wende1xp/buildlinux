+
+void __malloc_tls_teardown(pthread_t p)
+{
+	if (!p) return;
+	if (p->malloc_tls == (void *)&_mi_theap_empty) return;
+	_mi_thread_done((mi_theap_t *)p->malloc_tls);
+	p->malloc_tls = (void *)&_mi_theap_empty;
+	p->malloc_cache = (void *)&_mi_theap_empty;
+	p->malloc_main = 0;
+}
+
+void __malloc_atfork(int who)
+{
+	(void)who;
+}
+
+void __malloc_donate(char *start, char *end)
+{
+	(void)start;
+	(void)end;
+}
+
+void *__libc_calloc(size_t m, size_t n)
+{
+	return mi_calloc(m, n);
+}
+
+void *__libc_malloc_impl(size_t n)
+{
+	return mi_malloc(n);
+}
+
+void *__libc_realloc(void *p, size_t n)
+{
+	return mi_realloc(p, n);
+}
+
+void __libc_free(void *p)
+{
+	mi_free(p);
+}
+
+void *aligned_alloc(size_t align, size_t len)
+{
+	if ((align & -align) != align) {
+		errno = EINVAL;
+		return 0;
+	}
+
+	if (__malloc_replaced && !__aligned_alloc_replaced) {
+		errno = ENOMEM;
+		return 0;
+	}
+
+	void *p = mi_malloc_aligned(len, align);
+	if (!p && len) errno = ENOMEM;
+	return p;
+}
+
+size_t malloc_usable_size(void *p)
+{
+	return p ? mi_usable_size(p) : 0;
+}
