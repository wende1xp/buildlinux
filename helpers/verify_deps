verify_deps() {
    local MISS_DEP=0
    local dep

    echo "Verificação de dependências:"
    echo ""

    for dep in \
        clang clang++ cmake ninja meson \
        wget tar patch make ccache
    do
        if [ -n "$(command -v "$dep" 2>/dev/null)" ]; then
            echo "$dep : encontrado"
        else
            MISS_DEP=$((MISS_DEP + 1))
            echo "$dep : não encontrado"
        fi
    done

    echo ""

    if [ "$MISS_DEP" -ne 0 ]; then
        msg_error "Antes de prosseguir, instale as dependências necessárias."
        exit 1
    fi
}
